{
  "name": "looper",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "db:migrate": "pnpm --filter @looper/api db:migrate",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "pnpm --filter @looper/api test",
    "test:mvp": "pnpm --filter @looper/api test",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "latest",
    "turbo": "latest",
    "typescript": "6.0.3"
  }
}
